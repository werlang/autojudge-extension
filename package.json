{
  "name": "autojudge-extension",
  "displayName": "AutoJudge",
  "description": "Run and submit programming solutions to the AutoJudge API directly from Visual Studio Code, or connect to your own self-hosted AutoJudge server instance.",
  "version": "0.1.0",
  "publisher": "autojudge",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "autojudge",
    "judge",
    "competitive programming",
    "education",
    "testing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/werlang/autojudge-extension"
  },
  "scripts": {
    "build": "vsce package",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "homepage": "https://autojudge.io",
  "icon": "media/icon.png",
  "main": "./src/extension.js",
  "type": "module",
  "contributes": {
    "commands": [
      {
        "command": "autojudge.runActiveFile",
        "title": "AutoJudge: Run Active File",
        "icon": "$(play)"
      }
    ],
    "keybindings": [
      {
        "command": "autojudge.runActiveFile",
        "key": "ctrl+alt+r",
        "mac": "ctrl+alt+r",
        "when": "resourceScheme == file && editorLangId =~ /^(python|javascript|typescript|java|cpp|c|php)$/"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "autojudge.runActiveFile",
          "when": "resourceScheme == file && editorLangId =~ /^(python|javascript|typescript|java|cpp|c|php)$/",
          "group": "navigation@100"
        }
      ]
    },
    "configuration": {
      "title": "AutoJudge",
      "properties": {
        "autojudge.baseUrl": {
          "type": "string",
          "default": "https://api.autojudge.io",
          "description": "Full AutoJudge API base URL. Defaults to https://api.autojudge.io. Set this to your custom AutoJudge server URL if you're self-hosting."
        },
        "autojudge.testcasePath": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Optional testcase folder for the active run. Supports VS Code variables such as ${workspaceFolder} and ${fileDirname}. AutoJudge reads direct child .in files as inputs and, when every case has a matching .out file in the same folder, enables judge mode automatically. Leave blank to use the source file directory."
        }
      }
    }
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.1",
    "vitest": "^4.1.7"
  }
}
